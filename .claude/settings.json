      "Edit(**/node_modules/**)",
      "Edit(**/.next/**)",
      "Edit(**/out/**)",
      "Edit(**/build/**)",
      "Edit(**/dist/**)",
      "Bash(find /**/node_modules/**)",
      "Bash(find /**/.next/**)",
      "Bash(grep:* **/node_modules/**)",
      "Bash(grep:* **/.next/**)"

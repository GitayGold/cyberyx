    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/.next/**)",
      "Read(**/out/**)",
      "Read(**/build/**)",
      "Read(**/dist/**)",
      "Read(**/coverage/**)",
      "Read(**/.vercel/**)",
      "Read(**/.turbo/**)",
